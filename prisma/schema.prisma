generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Adventure {
  id              String      @id
  latestTurnIndex Int         @default(0)
  sceneTransitionMemory Json?
  sceneCameraContinuityState Json?
  seed            Int?
  state           Json?
  ownerId         String?
  turns           Turn[]
  turnEvents      TurnEvent[]

  @@index([ownerId])
}

model Turn {
  id          String    @id @default(cuid())
  adventureId String
  turnIndex   Int
  playerInput String
  scene       String
  resolution  Json
  stateDeltas Json
  ledgerAdds  Json
  memoryGate  String?
  debug       Json?
  intentJson  Json?
  createdAt   DateTime  @default(now())
  adventure   Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)

  @@unique([adventureId, turnIndex])
  @@index([adventureId])
}

model TurnEvent {
  eventId             String      @id @default(cuid())
  adventureId         String
  seq                 Int
  createdAt           DateTime    @default(now())
  prevEventId         String?
  idempotencyKey      String
  eventHash           String
  engineVersion       String
  status              String
  rejectReason        String?
  baseStateHash       String
  resultStateHash     String
  rngSeed             String
  playerInput         String
  modelInputHash      String
  turnJson            Json
  receiptEnvelopeHash String?
  receiptChainHash    String?
  receiptSig          String?
  adventure           Adventure   @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  prevEvent           TurnEvent?  @relation("TurnEventChain", fields: [prevEventId], references: [eventId], onDelete: Restrict)
  nextEvents          TurnEvent[] @relation("TurnEventChain")

  @@unique([adventureId, seq])
  @@index([adventureId, seq])
  @@index([adventureId])
}

model RateLimitBucket {
  id            String @id
  key           String
  bucketStartMs BigInt
  count         Int

  @@unique([key, bucketStartMs])
  @@index([key])
}

model UserUsage {
  id            String   @id @default(cuid())
  userId        String
  monthKey      String
  tier          Tier
  turnCount     Int      @default(0)
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)
  reservedTurns Int      @default(0)
  reservedTotal Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, monthKey])
  @@index([userId])
  @@index([monthKey])
}

model TurnBudgetHold {
  id                   String    @id @default(cuid())
  holdKey              String    @unique
  userId               String
  adventureId          String?
  tier                 Tier
  monthKey             String
  reservedTurns        Int       @default(1)
  reservedInputTokens  Int       @default(0)
  reservedOutputTokens Int       @default(0)
  reservedTotal        Int       @default(0)
  status               String    @default("HELD")
  expiresAt            DateTime
  releasedAt           DateTime?
  consumedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([holdKey])
  @@index([userId, monthKey])
  @@index([adventureId])
  @@index([expiresAt])
}

model TurnLease {
  id          String    @id @default(cuid())
  adventureId String    @unique
  userId      String
  leaseKey    String    @unique
  expiresAt   DateTime
  acquiredAt  DateTime  @default(now())
  releasedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([leaseKey])
  @@index([userId])
  @@index([expiresAt])
}

model Scenario {
  id               String             @id
  title            String
  summary          String?
  contentJson      Json
  visibility       ScenarioVisibility @default(PRIVATE)
  ownerId          String?
  sourceScenarioId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([visibility])
  @@index([ownerId])
}

model Save {
  id            String     @id
  scenarioId    String
  nextTurnIndex Int        @default(0)
  stateJson     Json
  ledgerJson    Json
  styleLockJson Json?
  turns         SaveTurn[]

  @@index([scenarioId])
}

model SaveTurn {
  id           String   @id
  saveId       String
  scenarioId   String
  artifactPath String?
  requestHash  String   @default("")
  createdIndex Int
  createdAt    DateTime @default(now())
  save         Save     @relation(fields: [saveId], references: [id], onDelete: Cascade)

  @@unique([saveId, createdIndex])
  @@index([saveId])
}

model UsageDay {
  key        String
  day        String
  turns      Int       @default(0)
  lastTurnAt DateTime?

  @@id([key, day])
}

enum SceneArtStatus {
  queued
  generating
  ready
  failed
  retryable
}

enum SceneArtPriority {
  low
  normal
  high
  critical
}

enum RenderMode {
  full
  partial
}

model SceneArt {
  id            String         @id @default(cuid())
  sceneKey      String
  promptHash    String
  title         String?
  basePrompt    String
  renderPrompt  String
  stylePreset   String?
  tagsJson      String?
  status        SceneArtStatus @default(queued)
  generationStartedAt DateTime?
  generationLeaseUntil DateTime?
  leaseOwnerId    String?
  leaseAcquiredAt DateTime?
  lastRecoveredAt DateTime?
  attemptCount  Int      @default(0)
  imageUrl      String?
  engineVersion String?
  renderMode    RenderMode     @default(full)
  totalCostUsd      Float     @default(0)
  lastAttemptCostUsd Float?
  billableAttemptCount Int    @default(0)
  providerModel     String?
  providerCostTier String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  renderPriority SceneArtPriority @default(normal)
  sceneArtShotCaches SceneArtShotCache[]
  lastProviderFailureClass String?
  lastProviderFailureReason String?
  lastProviderRetryable Boolean?
  lastProviderRetryDelayMs Int?
  lastProviderDurationMs Int?
  lastProviderAttemptAt DateTime?

  @@index([status])
  @@unique([sceneKey, promptHash])
}

model SceneArtShotCache {
  id         String    @id @default(cuid())
  sceneKey   String
  shotKey    String
  sceneArt   SceneArt  @relation(fields: [sceneArtId], references: [id], onDelete: Cascade)
  sceneArtId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([sceneKey, shotKey])
  @@index([sceneKey])
}

enum Tier {
  NOMAD
  TRAILBLAZOR
  CHRONICLER
  LOREMASTER
}

enum ScenarioVisibility {
  PRIVATE
  PUBLIC
}

model SceneArtWorkerState {
  id                 String   @id
  paused             Boolean  @default(false)
  draining           Boolean  @default(false)
  running            Boolean  @default(false)

  startedAt          DateTime?
  lastTickAt         DateTime?
  lastBatchAt        DateTime?
  lastProcessedCount Int      @default(0)
  lastDurationMs     Int?
  lastErrorAt        DateTime?
  lastErrorMessage   String?
  batchHistory       Json?
  lastBatchSummary   Json?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
